{
  "name": "@olivias/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run prerender:head && npm run sitemap:generate",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "images:generate": "node ./scripts/generate-responsive-images.mjs",
    "prerender:head": "node ./scripts/prerender-head.mjs",
    "sitemap:generate": "node ./scripts/generate-sitemap.mjs"
  },
  "dependencies": {
    "@olivias/ui": "file:../../packages/ui",
    "@stripe/stripe-js": "^7.9.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
